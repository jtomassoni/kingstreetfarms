# Copy to .env.local and fill in values

# Public contact email on the homepage (defaults to jtomassoni@gmail.com)
CONTACT_EMAIL=jtomassoni@gmail.com

# Required for CMS auth
ADMIN_USER=admin:yourpassword
# Or JSON: ADMIN_USER='{"username":"admin","password":"yourpassword"}'
# Or multiple: ADMIN_USERS=user1:pass1,user2:pass2

# Required for JWT session
SESSION_SECRET=your-random-secret-at-least-32-chars

# Database (works with local Postgres or Neon/cloud)
# Local: postgresql://user:pass@localhost:5432/kingstreetfarms
# Neon:  postgresql://user:pass@host.neon.tech/db?sslmode=require
DATABASE_URL=postgresql://user:pass@localhost:5432/kingstreetfarms
